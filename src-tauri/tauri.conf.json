{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LuoScope",
  "version": "2.12.3",
  "identifier": "com.robustluo.LuoScope",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1666",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "LuoScope",
        "width": 1200,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 680,
        "center": true,
        "decorations": false,
        "visible": false
      },
      {
        "label": "splashscreen",
        "title": "LuoScope",
        "width": 400,
        "height": 320,
        "center": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/48x48.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "windows": {
      "webviewInstallMode": {
        "type": "skip"
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": "nsis/header.bmp",
        "sidebarImage": "nsis/wizard.bmp",
        "installMode": "currentUser",
        "installerHooks": "nsis/installer-hooks.nsh",
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/RobustLuo/light-c/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYxMEU4MEYzRDdEODk1MDQKUldRRWxkalg4NEFPWVR3SjdDbkt0L2Q5TWUzaXdkc3lIejZqVzV6eHk1VkN6VzZCVlRURmVlQy8K"
    }
  }
}
